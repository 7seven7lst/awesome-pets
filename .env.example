# Copy to `.env` at repo root and adjust. `make install` copies this file to `server/.env`.

# Postgres URL — must match your DB (e.g. Docker from `make db_up` uses host port 5435, db novellia_pets)
DATABASE_URL="postgresql://postgres@127.0.0.1:5435/novellia_pets"

JWT_SECRET="dev-only-change-me-use-openssl-rand-base64-32-in-prod"

# Optional. API listen port (Express). Defaults to 3001 if unset.
BACKEND_PORT=3001
